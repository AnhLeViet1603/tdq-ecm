# ==============================================================
# E-Commerce Microservices - Environment Variables
# ==============================================================
# SECURITY: DO NOT commit this file to version control!
# Copy .env.example to .env and fill in your values.
# ==============================================================

# ── Django ────────────────────────────────────────────────────
DEBUG=True
DJANGO_SECRET_KEY=django-insecure-ecommerce-secret-key-change-in-production-2024

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=jwt-super-secret-key-change-in-production-2024
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=7

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secret_2024
POSTGRES_PORT=5432

# ── Database Names (per service) ──────────────────────────────
AUTH_DB_NAME=db_auth
PRODUCT_DB_NAME=db_product
INVENTORY_DB_NAME=db_inventory
CART_DB_NAME=db_cart
ORDER_DB_NAME=db_order
PAYMENT_DB_NAME=db_payment
PROMOTION_DB_NAME=db_promotion
REVIEW_DB_NAME=db_review
SHIPPING_DB_NAME=db_shipping

# ── Service Ports ─────────────────────────────────────────────
GATEWAY_PORT=8000
AUTH_PORT=8001
PRODUCT_PORT=8002
INVENTORY_PORT=8003
CART_PORT=8004
ORDER_PORT=8005
PAYMENT_PORT=8006
PROMOTION_PORT=8007
REVIEW_PORT=8008
SHIPPING_PORT=8009

# ── Internal Service URLs (Docker network DNS) ────────────────
AUTH_SERVICE_URL=http://auth:8001
PRODUCT_SERVICE_URL=http://product:8002
INVENTORY_SERVICE_URL=http://inventory:8003
CART_SERVICE_URL=http://cart:8004
ORDER_SERVICE_URL=http://order:8005
PAYMENT_SERVICE_URL=http://payment:8006
PROMOTION_SERVICE_URL=http://promotion:8007
REVIEW_SERVICE_URL=http://review:8008
SHIPPING_SERVICE_URL=http://shipping:8009

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=*

# ── Admin Seed Account ────────────────────────────────────────
# Auto-created on first startup of auth service
ADMIN_EMAIL=admin@shopvn.com
ADMIN_PASSWORD=Admin@123456
ADMIN_FULL_NAME=Super Admin
